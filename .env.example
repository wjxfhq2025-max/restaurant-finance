# 服务器配置
PORT=3000
SESSION_SECRET=your-session-secret-here

# PostgreSQL 数据库（使用 Neon 连接字符串）
DATABASE_URL=postgresql://user:password@ep-xxx-xxx.us-east-1.aws.neon.tech/restaurant_finance?sslmode=require

# Cloudinary 配置
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
